@model List<SDGP_VVP.Web.Models.MedicoViewModel>

@{
    ViewData["Title"] = "Médicos";
}

<div class="container mt-5">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-primary text-white">

            <h3 class="mb-0">
                👨‍⚕️ Médicos Disponibles
            </h3>

        </div>

        <div class="card-body">

            <table class="table table-hover">

                <thead class="table-primary">

                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Especialidad</th>
                        <th>CMP</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var medico in Model)
                    {
                        <tr>

                            <td>@medico.IdMedico</td>

                            <td>@medico.Nombre</td>

                            <td>@medico.Especialidad</td>

                            <td>@medico.CMP</td>

                        </tr>
                    }

                </tbody>

            </table>

            <a asp-controller="Dashboard"
                   asp-action="Index"
                   class="btn btn-outline-secondary">

                ← Volver al Dashboard

            </a>

        </div>

    </div>

</div>